<Window
    x:Class="MriAPPDriverMgrWin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MriAPPDriverMgrWin"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="MRI APPDriver Manager">

    <Grid Margin="16" RowSpacing="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="MRI APPDriver Manager"
                           Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock x:Name="TargetMachineText"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource SystemFillColorCautionBrush}"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <TextBlock x:Name="LastRefreshText"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Style="{StaticResource CaptionTextBlockStyle}"/>
                <Button x:Name="RefreshButton"
                        Content="&#xE72C; Refresh"
                        FontFamily="Segoe MDL2 Assets"
                        Click="RefreshButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Status bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <ProgressRing x:Name="LoadingRing" IsActive="False" Width="20" Height="20"/>
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Text="Ready"/>
        </StackPanel>

        <!-- Process DataGrid -->
        <ScrollViewer Grid.Row="2" HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Auto">
            <ListView x:Name="ProcessListView"
                      ItemsSource="{x:Bind ProcessRows}"
                      SelectionMode="None"
                      IsItemClickEnabled="False">

                <ListView.Header>
                    <Grid x:Name="GridHeader"
                          Background="{ThemeResource SystemFillColorSolidAttentionBackgroundBrush}"
                          Padding="12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Machine"      FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="PID"          FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="Session ID"   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="User ID"      FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="4" Text="Start Time"   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="5" Text="Running"      FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="6" Text="CPU %"        FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="7" Text="Memory (MB)"  FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="8" Text="Report"       FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="9" Text=""             FontWeight="SemiBold"/>
                    </Grid>
                </ListView.Header>

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:ProcessRow">
                        <Grid Padding="12,6"
                              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{x:Bind MachineName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind ProcessId}"   VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind SessionId}"   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="3" Text="{x:Bind UserId}"      VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="4" Text="{x:Bind StartTime}"   VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="{x:Bind Running}"     VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="{x:Bind CpuPercent}"  VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="7" Text="{x:Bind MemoryMb}"    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="8" Text="{x:Bind ReportName}"  VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                            <Button Grid.Column="9"
                                    Content="Kill"
                                    Tag="{x:Bind ProcessId}"
                                    Click="KillButton_Click"
                                    Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                    Padding="12,4"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>
        </ScrollViewer>

        <!-- Footer -->
        <TextBlock Grid.Row="3"
                   x:Name="FooterText"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Style="{StaticResource CaptionTextBlockStyle}"/>

    </Grid>
</Window>
